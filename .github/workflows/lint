name: Lint

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

jobs:
  lint:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      # 1. Install uv and cache dependencies automatically
      - name: Install uv
        uses: astral-sh/setup-uv@v5
        with:
          enable-cache: true # This makes your builds lightning fast

      # 2. Use uv to run tools directly (no need to manually install ruff/mypy)
      - name: Run Ruff Check
        run: uv run ruff check .

      - name: Run Ruff Format
        run: uv run ruff format --check .

      - name: Run Mypy
        run: uv run mypy .
