root=true

[*]
# Universal settings
indent_style=space
indent_size=4
charset=utf-8
end_of_line=lf
trim_trailing_whitespace=true
insert_final_newline=true
max_line_length=88

# Python overrides
[*.py]
indent_style=space
indent_size=4

# Web Frontend Standard: often uses 2-space indents
[*.{html,css,scss,js,json}]
indent_size=2

# Configuration files
[*.{yml,yaml,toml}]
indent_size=2

# Documentation
[*.md]
trim_trailing_whitespace=false

# System files the REQUIRE actual tabs
[Makefile]
indent_style=tab